{
    "name": "Layer1/lockfree_queue/architecture.json",
    "module": "lockfree_queue",
    "threading_model": {
        "enqueue": "multi-producer",
        "dequeue": "single-consumer",
        "memory_model": "lock-free"
    },
    "determinism": {
        "single_consumer_ordering": true,
        "cross_producer_global_ordering": false,
        "per_producer_fifo": true
    },
    "performance": {
        "target_contention": "high",
        "enqueue_complexity": "O(1)",
        "dequeue_complexity": "O(1)"
    },
    "ownership": {
        "producer_owns_message_before_enqueue": true,
        "consumer_owns_message_after_dequeue": true
    },
    "future_evolution": {
        "queue_backend": [
            "mpsc_ring_buffer",
            "intrusive_node_queue"
        ]
    }
}