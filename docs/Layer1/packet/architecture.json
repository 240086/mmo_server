{
    "name": "Layer1/packet/architecture.json",
    "module": "packet",
    "threading_model": {
        "writer": "single-owner",
        "reader": "single-owner",
        "cross_thread_access": false
    },
    "ownership_model": {
        "packet_buffer": "unique_owner",
        "packet_view": "non_owning"
    },
    "design_principles": [
        "zero_copy_view",
        "explicit_ownership",
        "binary_transport_only",
        "no_network_logic",
        "no_gameplay_logic"
    ],
    "performance": {
        "heap_allocations": "minimized",
        "copy_policy": "explicit",
        "packet_header_fixed_size": true
    },
    "future_evolution": {
        "compression": true,
        "encryption": true,
        "scatter_gather_io": true
    }
}